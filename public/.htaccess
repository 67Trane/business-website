# Apache config for the prerendered Angular site (all-inkl shared hosting)

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Serve existing files and directories directly,
# route every unknown URL to the prerendered index.html (Angular handles it)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ /index.html [L]

<IfModule mod_headers.c>
  # Hashed JS/CSS/font files never change -> cache for one year
  <FilesMatch "\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Images keep their names -> cache for 30 days
  <FilesMatch "\.(webp|jpe?g|png|ico|svg)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  # HTML must always be revalidated so deployments show up immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  # Compress text-based assets (fonts/images are already compressed)
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
