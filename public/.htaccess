# Apache config for the prerendered Angular site (all-inkl shared hosting)

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Serve existing files and directories directly,
# route every unknown URL to the prerendered index.html (Angular handles it)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ /index.html [L]

<IfModule mod_headers.c>
  # Hashed JS/CSS files never change -> cache for one year
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML must always be revalidated so deployments show up immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
